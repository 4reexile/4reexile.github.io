---
import { getCollection } from 'astro:content'

const friends = await getCollection('friends')
const friendSites = friends.filter((item) => item.data.group === 'friend')
const stackSites = friends.filter((item) => item.data.group === 'stack')
---

<div class="space-y-10">
  <section class="space-y-4">
    <h2 class="text-2xl font-bold">朋友们</h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-8">
      {
        friendSites.map((friend) => (
          <li>
            <a href={friend.data.link} target="_blank" rel="noopener noreferrer external">
              <div class="p-4 flex gap-2 bg-accent/10 rounded-lg group">
                <img
                  class="shrink-0 size-16 object-contain rounded-full"
                  src={friend.data.avatar}
                  alt={`Friend avatar: ${friend.data.title}`}
                  loading="lazy"
                />
                <div class="min-w-0 grow">
                  <div class="truncate font-bold text-xl group-hover:text-accent">
                    {friend.data.title}
                  </div>
                  <div class="text-sm line-clamp-2">{friend.data.description}</div>
                </div>
                <i class="shrink-0 iconfont icon-external-link group-hover:text-accent" />
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  {
    stackSites.length > 0 && (
      <section class="space-y-4">
        <h2 class="text-2xl font-bold">技术</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-8">
          {
            stackSites.map((site) => (
              <li>
                <a href={site.data.link} target="_blank" rel="noopener noreferrer external">
                  <div class="p-4 flex gap-2 bg-accent/10 rounded-lg group">
                    <img
                      class="shrink-0 size-16 object-contain rounded-full"
                      src={site.data.avatar}
                      alt={`Stack avatar: ${site.data.title}`}
                      loading="lazy"
                    />
                    <div class="min-w-0 grow">
                      <div class="truncate font-bold text-xl group-hover:text-accent">
                        {site.data.title}
                      </div>
                      <div class="text-sm line-clamp-2">{site.data.description}</div>
                    </div>
                    <i class="shrink-0 iconfont icon-external-link group-hover:text-accent" />
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    )
  }
</div>
