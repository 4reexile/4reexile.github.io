<script is:inline>
  const THEME_KEY = 'gyoza-theme'
  const MOURNING_DAYS = ['4-4', '5-12', '7-7', '9-18', '12-13']

  function getSystemTheme() {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
  }

  function getLocalTheme() {
    const local = localStorage.getItem(THEME_KEY)
    if (local === 'dark' || local === 'light' || local === 'system') {
      return local
    }
    localStorage.setItem(THEME_KEY, 'system')
    return 'system'
  }

  function isMourningDay() {
    const today = new Date()
    const dateStr = `${today.getMonth() + 1}-${today.getDate()}`
    return MOURNING_DAYS.includes(dateStr)
  }

  function applyTheme() {
    const localTheme = getLocalTheme()
    const nextTheme = localTheme === 'system' ? getSystemTheme() : localTheme
    document.documentElement.setAttribute('data-theme', nextTheme)

    if (isMourningDay()) {
      document.documentElement.classList.add('gray')
    }
  }

  applyTheme()
  document.addEventListener('swup:content:replace', applyTheme)
</script>
